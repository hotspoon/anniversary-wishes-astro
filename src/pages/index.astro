---
const featuredPhotos = [
  { src: "/photos/0c662fc8-a4f9-476f-a4f4-e3aca31bd922.jpg", caption: "Yang paling aku cari 🌸", layout: "tall" },
  { src: "/photos/4ec86829-3f84-4a3b-92ce-5c99edd61291.jpg", caption: "Aku sayang banget sama kamu 🌹", layout: "short" },
  { src: "/photos/2c424ea7-710a-4f8f-a0e9-9f2d17ffe124.jpg", caption: "Makasih ya sudah hadir di hidup aku 🌻", layout: "short" },
  { src: "/photos/15561f40-4577-4dbb-b411-454e558889ef.jpg", caption: "Orang favoritku ❤️", layout: "tall" },
];

const ornaments = ["🎀", "⭐", "💫", "🌸"];
const ropes = ["#ff9fcf", "#ffd84f", "#9be7c5", "#fff08a"];
---
<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Untuk Sayangku Tercinta</title>
    <meta
      name="description"
      content="Hal kecil buat anniversary kita."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=Montserrat:wght@300;400;500&family=Parisienne&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Lato:wght@300;400&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.cdnfonts.com/css/brittany-signature"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/style.css" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <!-- ========== GLOBAL STARS BG (persists across all scenes) ========== -->
    <canvas id="starsCanvas" class="stars-canvas-global"></canvas>

    <!-- ========== AUDIO ========== -->
    <audio id="bgMusic" loop>
      <source src="/taylor_swift_enchanted.mp3" type="audio/mpeg" />
    </audio>
    <!-- ========== MUSIC CONTROL ========== -->
    <div id="musicControl" class="music-btn">
      <button
        id="muteBtn"
        type="button"
        title="Nyalakan atau matikan musik"
        aria-label="Nyalakan atau matikan musik"
      >
        <span id="musicIcon">🎵</span>
      </button>
    </div>

    <!-- ========== CURSOR HEARTS ========== -->
    <canvas id="cursorCanvas"></canvas>

    <!-- ========== SCENE 0: COUNTDOWN ========== -->
    <section id="scene-countdown" class="scene active">
      <div class="countdown-bg"></div>
      <div class="countdown-particles" id="countdownParticles"></div>
      <div class="countdown-fog"></div>
      <div class="countdown-container">
        <div class="countdown-msg-wrapper">
          <p id="countdownMessage" class="countdown-message"></p>
        </div>
        <div id="countdownTimer" class="countdown-timer">
          00 HARI : 00 JAM : 00 MENIT : 00 DETIK
        </div>
        <div class="enter-btn-wrapper" id="enterBtnWrapper" style="display: none">
          <button id="enterBtn" class="enter-btn" type="button">Buka kejutannya ✨</button>
        </div>
        <div class="open-sooner-wrapper" id="openSoonerWrapper">
          <button id="openSoonerBtn" class="open-sooner-btn" type="button">Mau buka duluan?</button>
        </div>
      </div>
      <div id="passwordModal" class="password-modal">
        <div class="password-modal-content">
          <p class="password-prompt">Masukin kata rahasianya dulu, sayang.</p>
          <input type="password" id="passwordInput" class="password-input" placeholder="..." />
          <button id="passwordSubmit" class="password-submit" type="button">Buka</button>
          <p id="passwordError" class="password-error"></p>
          <button id="closeModalBtn" class="close-modal-btn" type="button">Batal</button>
        </div>
      </div>
    </section>

    <!-- ========== SCENE 1: UNLOCK MY HEART ========== -->
    <section id="scene-unlock" class="scene">
      <div class="floating-hearts-bg" id="floatingHeartsBg"></div>
      <div class="unlock-container">
        <div class="unlock-center">
          <div class="unlock-top-text">
            <p class="pre-text">Dari awal, kamu memang yang paling aku cari.</p>
          </div>
          <div class="lock-key-area">
            <div class="heart-lock" id="heartLock">
              <svg class="heart-lock-svg" viewBox="0 0 120 110" xmlns="http://www.w3.org/2000/svg">
                <defs>
                  <radialGradient id="heartGrad" cx="50%" cy="50%" r="50%">
                    <stop offset="0%" stop-color="#ffd6ea"/>
                    <stop offset="55%" stop-color="#ff9fcf"/>
                    <stop offset="100%" stop-color="#4fb477"/>
                  </radialGradient>
                  <filter id="heartGlow">
                    <feGaussianBlur stdDeviation="4" result="blur"/>
                    <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
                  </filter>
                </defs>
                <path class="heart-path" d="M60 95 C60 95 10 65 10 35 C10 18 22 8 35 8 C44 8 52 13 60 22 C68 13 76 8 85 8 C98 8 110 18 110 35 C110 65 60 95 60 95Z" filter="url(#heartGlow)"/>
                <rect class="lock-body" x="43" y="50" width="34" height="26" rx="5" ry="5"/>
                <path class="lock-shackle" d="M50 50 L50 40 Q60 28 70 40 L70 50" fill="none" stroke-width="5" stroke-linecap="round"/>
                <circle class="keyhole" cx="60" cy="62" r="5"/>
                <rect class="keyhole" x="57" y="62" width="6" height="8" rx="2"/>
              </svg>
              <div class="heart-glow-ring"></div>
            </div>
            <div class="key-wrapper" id="keyWrapper">
              <div class="key-drag" id="keyDrag" draggable="true">
                <svg class="key-svg" viewBox="0 0 80 30" xmlns="http://www.w3.org/2000/svg">
                  <defs>
                    <linearGradient id="keyGrad" x1="0%" y1="0%" x2="100%" y2="0%">
                      <stop offset="0%" stop-color="#fff3a6"/>
                      <stop offset="50%" stop-color="#ffd84f"/>
                      <stop offset="100%" stop-color="#4fb477"/>
                    </linearGradient>
                  </defs>
                  <circle cx="14" cy="15" r="11" fill="none" stroke="url(#keyGrad)" stroke-width="4"/>
                  <circle cx="14" cy="15" r="5" fill="url(#keyGrad)"/>
                  <rect x="24" y="13" width="42" height="4" rx="2" fill="url(#keyGrad)"/>
                  <rect x="52" y="17" width="4" height="7" rx="1" fill="url(#keyGrad)"/>
                  <rect x="60" y="17" width="4" height="5" rx="1" fill="url(#keyGrad)"/>
                </svg>
                <span class="key-hint">geser aku ✨</span>
              </div>
            </div>
          </div>
          <p class="sub-text" id="subText">Coba buka pelan-pelan ya.</p>
          <p class="miss-text" id="missText"></p>
        </div>
      </div>
      <div class="unlock-overlay" id="unlockOverlay"></div>
    </section>

    <!-- ========== SCENE 2: ANNIVERSARY REVEAL ========== -->
    <section id="scene-birthday" class="scene">
      <canvas id="confettiCanvas" class="confetti-canvas"></canvas>
      <canvas id="petalCanvas" class="petal-canvas"></canvas>
      <div class="particles-bg" id="particlesBg"></div>
      <div class="birthday-container">
        <div class="birthday-header" id="birthdayHeader">
          <h1 class="birthday-title" id="birthdayTitle">
            Selamat Anniversary<br/><span class="birthday-name">Sayangku, Azlia Saraswati Pramono</span>
          </h1>
          <div class="birthday-subtitle-spacer"></div>
          <p class="birthday-subtitle" id="birthdaySubtitle">buat orang yang paling aku sayang sayang bingittttt ❤️❤️❤️.</p>
        </div>
        <div class="wish-container" id="wishContainer" style="display: none">
        </div>
      </div>
    </section>

    <!-- ========== SCENE 3: FINAL EMOTIONAL ENDING ========== -->
    <section id="scene-ending" class="scene">
      <div class="ending-bg"></div>
      <div class="ending-particles" id="endingParticles"></div>
      <div class="ending-scroll-wrapper">
        <div class="ending-container">
          <div class="ending-ornament-top">❤️</div>
          <p class="ending-text" id="endingText"></p>
          <div class="ending-ornament-bottom">✦ ✦ ✦</div>
          <button class="gallery-btn" id="galleryBtn" type="button" style="display: none">
            Lihat senyum kamu di sini ya sayang 🌸
          </button>
        </div>
      </div>
    </section>

    <!-- ========== SCENE 4: HANGING PHOTO GALLERY ========== -->
    <section id="scene-gallery" class="scene">
      <div class="gallery-bg"></div>
      <div class="gallery-particles" id="galleryParticles"></div>

      <div class="gallery-scroll-wrapper">
        <div class="gallery-container">
          <!-- Top 4 featured hanging frames — rendered server-side with Astro Image -->
          <div class="featured-frames" id="featuredFrames">
            {featuredPhotos.map((photo, i) => (
              <div class={`featured-frame ${photo.layout}`} style={`animation-delay: ${i * 0.3}s; --swing-delay: ${i * 0.5}s`}>
                <div class="rope" style={`background: linear-gradient(to bottom, ${ropes[i % ropes.length]}cc, ${ropes[i % ropes.length]}44)`}></div>
                <div class="rope-ornament">{ornaments[i % ornaments.length]}</div>
                <div class="hang-card">
                  <img src={photo.src} alt={photo.caption} class="hang-media" loading="eager" />
                  <div class="hang-caption">{photo.caption}</div>
                </div>
              </div>
            ))}
          </div>

          <!-- Center title -->
          <div class="gallery-header">
            <div class="gallery-ornament">✦ ✦ ✦</div>
            <h2 class="gallery-title">Senyum yang selalu aku cari</h2>
            <p class="gallery-subtitle">Semua foto yang berharga ini, tiap momennya selalu berhasil bikin aku senyum lagi sayang.</p>
            <div class="gallery-ornament">✦ ✦ ✦</div>
          </div>

          <!-- Remaining media grid -->
          <div class="remaining-gallery" id="remainingGallery">
          </div>

          <div class="gallery-footer">
            <p class="gallery-footer-text">
              Selamat anniversary, sayangku yang paling cantikk bingitttt. Makasih yaa uda jadi bagian paling berharga dari hari-hariku. ❤️
            </p>
          </div>
        </div>
      </div>
    </section>

    <script type="module" src="/js/main.js" is:inline></script>
  </body>
</html>
